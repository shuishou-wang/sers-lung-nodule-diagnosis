# ===========================================
#  SERS 肺结节智能诊断系统 — 环境变量配置
#  复制为 .env 并填入真实值
# ===========================================

# --- Flask ---
FLASK_SECRET_KEY=change-me-to-a-random-string

# --- 登录凭证 ---
APP_USERNAME=admin
APP_PASSWORD=your-password-here

# --- LLM 后端 (SiliconFlow, OpenAI 兼容) ---
SILICONFLOW_API_KEY=sk-your-key-here

# --- 训练数据路径 (仅训练时需要) ---
DATA_PATH=data/肿瘤标志物+拉曼数据+年龄性别.xlsx
